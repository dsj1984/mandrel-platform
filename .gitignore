
# Installed dependencies — restored from package-lock.json, never committed.
node_modules/

# Workspace scratch dir (CLAUDE.md §6) — transient outputs, excluded from Git.
temp/

# Per-Story git worktrees created by story-init.js during /deliver and reaped
# by story-close.js — transient delivery-time state, never committed. Leaving
# it untracked-but-not-ignored trips story-close's branch-restore guard
# ("working tree is dirty") after a Story close.
.worktrees/

# Claude Code command projection is generated from .agents/workflows/ — do not commit.
.claude/commands/

# Project-scoped MCP config carries secrets — keep out of git.
.mcp.json

# Secrets live in .env (e.g. GITHUB_TOKEN) — never commit it. Only .env.example (placeholders) is checked in.
.env

# Auto-managed active-story marker — regenerated on story-init, deleted on story-close. Never committed.
.env.local

# Per-developer local overrides (CLAUDE.md §1.E) — personal prefs, never committed.
.agentrc.local.json
.agents/instructions.local.md

# Per-clone install record written by bootstrap — not a source artifact.
.agents/.install-manifest.json
