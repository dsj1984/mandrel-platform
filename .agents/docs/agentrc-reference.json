{
  "$schema": "../schemas/agentrc.schema.json",
  "project": {
    "baseBranch": "main",
    "paths": {
      "agentRoot": ".agents",
      "docsRoot": "docs",
      "tempRoot": "temp"
    },
    "docsContextFiles": [
      "architecture.md",
      "data-dictionary.md",
      "decisions.md",
      "patterns.md"
    ],
    "commands": {
      "lintBaseline": "npx eslint . --format json",
      "test": "npm test",
      "typecheck": null,
      "formatCheck": "npx biome format .",
      "formatWrite": "npx biome format --write ."
    }
  },
  "github": {
    "owner": "[OWNER]",
    "repo": "[REPO]",
    "projectNumber": null,
    "projectOwner": null,
    "operatorHandle": "@[USERNAME]",
    "defaultTimeoutMs": 60000,
    "branchProtection": {
      "enforce": true,
      "requiredChecks": [
        {
          "name": "lint",
          "cmd": ["npm", "run", "lint"]
        },
        {
          "name": "test",
          "cmd": ["npm", "test"]
        },
        {
          "name": "baselines",
          "cmd": ["node", ".agents/scripts/check-baselines.js"]
        }
      ]
    },
    "mergeMethods": {
      "allow_squash_merge": true,
      "allow_rebase_merge": false,
      "allow_merge_commit": false,
      "allow_auto_merge": true,
      "delete_branch_on_merge": true
    },
    "notifications": {
      "mentionOperator": false,
      "commentEvents": ["state-transition", "story-merged", "operator-message"],
      "webhookEvents": [
        "state-transition",
        "story-merged",
        "story-closing",
        "operator-message",
        "merge.unlanded",
        "merge.flip-failed",
        "loop.tick"
      ]
    }
  },
  "planning": {
    "codebaseSnapshot": {
      "tier": "skinny",
      "include": [
        ".agents/scripts/**",
        "src/**",
        "lib/**",
        "app/**",
        "packages/**"
      ],
      "exclude": [
        "**/node_modules/**",
        "**/dist/**",
        "**/build/**",
        "**/.next/**",
        "**/.turbo/**",
        "**/coverage/**",
        "**/*.test.*",
        "**/*.spec.*"
      ],
      "recentCommitWindow": 30
    },
    "riskHeuristics": [
      "Destructive or irreversible data mutations (dropping tables, deleting rows without soft-delete or backup, truncating production state).",
      "Modifications to shared security or auth infrastructure (IAM policies, auth middleware, session or token handling, secret rotation).",
      "Changes to CI/CD, deployment pipelines, or release gating that could disable safety checks or ship unverified code to production.",
      "Monorepo-wide AST or text replacements touching overlapping files in parallel (catastrophic merge-conflict risk across concurrent agents).",
      "Schema migrations that rewrite existing rows or drop columns without a backfill or rollback plan."
    ],
    "failOnSharedEditors": false,
    "requireExplicitCrossStoryDeps": false,
    "failOnRegistryConflicts": false,
    "failOnLargeFanOut": false,
    "largeFanOutThreshold": 10,
    "crossCuttingRegistries": [
      "lib/orchestration/lifecycle/listeners/index.js",
      "**/listeners/index.js",
      "**/handlers/index.js"
    ],
    "navigation": {
      "routeGlobs": [],
      "navRegistry": []
    }
  },
  "delivery": {
    "execution": {
      "timeoutMs": 600000
    },
    "lease": {
      "ttlMs": 900000
    },
    "ci": {
      "watch": {
        "pollIntervalMs": 10000,
        "maxPolls": 180,
        "maxResumes": 3
      },
      "autoMerge": "trust-ci"
    },
    "docsFreshness": {
      "paths": ["README.md"]
    },
    "deliverRunner": {
      "concurrencyCap": 3
    },
    "worktreeIsolation": {
      "enabled": true,
      "root": ".worktrees",
      "nodeModulesStrategy": "clone",
      "primeFromPath": null,
      "allowSymlinkOnWindows": false,
      "reapOnSuccess": true,
      "bootstrapFiles": [
        ".env",
        ".mcp.json",
        ".agentrc.local.json",
        ".agents/instructions.local.md"
      ]
    },
    "signals": {
      "rework": {
        "editsPerFile": 5
      },
      "retry": {
        "repeatCount": 3
      }
    },
    "mergeWatch": {
      "intervalSeconds": 30,
      "maxBudgetSeconds": 3600
    },
    "codeReview": {
      "providers": [
        {
          "name": "native"
        },
        {
          "name": "security-review",
          "scopes": ["story"],
          "optional": true
        },
        {
          "name": "ultrareview",
          "scopes": ["story"],
          "manualPrompt": true,
          "when": {
            "label": "risk::high"
          }
        }
      ],
      "maxFixAttempts": 3,
      "maxFixScopeFiles": 5,
      "autoFixSeverity": "medium"
    },
    "routing": {
      "roleScopedAgents": true,
      "freshCriticSampleRate": 0.2,
      "ceremonyProfile": "standard",
      "closeAndLand": true
    },
    "feedbackLoop": {
      "auditResultsAutoFile": true,
      "retroProposals": true
    },
    "quality": {
      "gateScoping": {
        "scope": "diff",
        "diffRef": "main"
      },
      "gates": {
        "lint": {
          "enabled": true,
          "baselinePath": "baselines/lint.json",
          "tolerance": {
            "kind": "absolute",
            "value": 0
          },
          "floors": {
            "*": {
              "errorCount": 0
            }
          }
        },
        "coverage": {
          "enabled": true,
          "baselinePath": "baselines/coverage.json",
          "tolerance": {
            "kind": "absolute",
            "value": 0
          },
          "floors": {
            "*": {
              "lines": 90,
              "branches": 85,
              "functions": 90
            }
          },
          "coveragePath": "coverage/coverage-final.json",
          "timeoutMs": 600000
        },
        "crap": {
          "enabled": true,
          "baselinePath": "baselines/crap.json",
          "tolerance": {
            "kind": "absolute",
            "value": 0.05
          },
          "floors": {
            "*": {
              "max": 30,
              "p95": 20,
              "methodsAbove20": 50
            }
          },
          "targetDirs": ["src"],
          "newMethodCeiling": 30,
          "requireCoverage": true,
          "friction": {
            "markerKey": "crap-baseline-regression"
          },
          "refreshTag": "baseline-refresh:",
          "refreshTimeoutMs": 60000,
          "ignoreGlobs": []
        },
        "maintainability": {
          "enabled": true,
          "baselinePath": "baselines/maintainability.json",
          "tolerance": {
            "kind": "absolute",
            "value": 0.5
          },
          "floors": {
            "*": {
              "min": 70
            }
          },
          "targetDirs": [],
          "refreshTimeoutMs": 60000,
          "ignoreGlobs": []
        },
        "mutation": {
          "enabled": true,
          "baselinePath": "baselines/mutation.json",
          "tolerance": {
            "kind": "percent",
            "value": 0
          },
          "floors": {
            "*": {
              "score": 60
            }
          },
          "strykerConfigPath": null
        },
        "lighthouse": {
          "enabled": false,
          "baselinePath": "baselines/lighthouse.json",
          "tolerance": {
            "kind": "absolute",
            "value": 0
          },
          "floors": {
            "*": {
              "performance": 0,
              "accessibility": 0,
              "bestPractices": 0,
              "seo": 0
            }
          },
          "baseUrl": null,
          "routes": []
        },
        "bundle-size": {
          "enabled": false,
          "baselinePath": "baselines/bundle-size.json",
          "tolerance": {
            "kind": "percent",
            "value": 0
          },
          "floors": {
            "*": {}
          },
          "bundles": []
        },
        "duplication": {
          "enabled": false,
          "baselinePath": "baselines/duplication.json",
          "tolerance": {
            "kind": "absolute",
            "value": 1
          },
          "floors": {
            "*": {
              "percentage": 25
            }
          },
          "targetDirs": ["src"],
          "refreshTimeoutMs": 60000,
          "ignoreGlobs": []
        }
      },
      "formatAutofix": {
        "timeoutMs": 60000
      },
      "codingGuardrails": {
        "cyclomaticFlag": 8,
        "cyclomaticMustFix": 12,
        "requireSiblingTest": false
      },
      "autoRefresh": {
        "enabled": true,
        "crapJumpCap": 5,
        "scope": "diff"
      },
      "baselineEpsilon": {
        "maintainability": 0.5,
        "crap": 0.5,
        "coverage": 0.1,
        "mutation": 0.5,
        "lint": 0,
        "lighthouse": 1,
        "bundle-size": 1024,
        "duplication": 0.5
      },
      "requireBaselines": false,
      "navigability": {
        "routeGlobs": [],
        "navRegistry": []
      }
    },
    "refactorStage": {
      "enabled": false
    },
    "acceptanceEval": {
      "maxRounds": 2,
      "clusterCeiling": 4
    }
  },
  "qa": {
    "featureRoot": "tests/features",
    "fixturesManifest": "tests/fixtures/personas.json",
    "environments": {
      "local": {
        "baseUrl": "http://localhost:3000",
        "signInSeam": {
          "urlTemplate": "/dev/sign-in-as/{persona}"
        }
      },
      "staging": {
        "baseUrl": "https://staging.example.test",
        "signInSeam": {
          "skill": "stack/qa/sign-in"
        },
        "allowWrites": false
      }
    },
    "personas": {
      "admin": {
        "credentialRef": "QA_ADMIN_CREDENTIAL"
      },
      "member": {
        "signInSkill": "stack/qa/sign-in-member"
      }
    },
    "consoleAllowlist": ["Download the React DevTools", "[HMR]"],
    "designTokens": "src/styles/tokens.css"
  }
}
