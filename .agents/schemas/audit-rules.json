{
  "version": 1,
  "audits": {
    "audit-clean-code": {
      "triggers": { "gates": ["gate1", "gate3"], "filePatterns": ["**/*"] },
      "scope": "local",
      "substitutionKeys": []
    },
    "audit-architecture": {
      "triggers": {
        "gates": ["gate1", "gate3"],
        "filePatterns": [".agents/scripts/lib/**", "lib/**", "bin/**", "src/**"]
      },
      "scope": "cumulative",
      "substitutionKeys": []
    },
    "audit-data-model": {
      "triggers": {
        "gates": ["gate1", "gate3"],
        "keywords": [
          "migration",
          "schema",
          "orm",
          "prisma",
          "foreign key",
          "constraint",
          "cascade",
          "backfill"
        ],
        "filePatterns": [
          "**/migrations/**",
          "**/migrate/**",
          "**/seeds/**",
          "**/*.sql",
          "**/*.prisma",
          "**/entities/**",
          "**/models/**"
        ]
      },
      "target": "data-model",
      "scope": "local",
      "substitutionKeys": []
    },
    "audit-security": {
      "triggers": {
        "gates": ["gate1", "gate3"],
        "keywords": [
          "security",
          "auth",
          "vulnerability",
          "cve",
          "password",
          "encrypt"
        ],
        "filePatterns": [
          "**/*.lock",
          "**/auth/**",
          "**/authn/**",
          "**/authz/**",
          "**/middleware/**",
          "**/crypto/**",
          "**/session/**",
          "**/*credential*",
          "**/*permission*",
          "**/*.pem",
          "**/*.key"
        ]
      },
      "scope": "local",
      "substitutionKeys": []
    },
    "audit-privacy": {
      "triggers": {
        "gates": ["gate1", "gate3"],
        "keywords": [
          "privacy",
          "pii",
          "gdpr",
          "cookie",
          "tracking",
          "telemetry",
          "analytics",
          "logging",
          "consent"
        ],
        "filePatterns": [
          "**/user-profile/**",
          "**/*logger*",
          "**/*logging*",
          "**/logging/**",
          "**/*telemetry*",
          "**/telemetry/**",
          "**/*analytics*",
          "**/analytics/**"
        ]
      },
      "scope": "local",
      "substitutionKeys": []
    },
    "audit-accessibility": {
      "triggers": {
        "gates": ["gate2", "gate3"],
        "keywords": [
          "a11y",
          "accessibility",
          "wcag",
          "aria",
          "screen reader",
          "keyboard",
          "focus",
          "contrast",
          "alt text",
          "label"
        ],
        "filePatterns": [
          "**/*.html",
          "**/*.astro",
          "**/components/**/*.{js,jsx,ts,tsx,vue,svelte}",
          "**/app/**/{page,layout,route,head,default,template,loading,error,not-found}.{js,jsx,ts,tsx}",
          "**/pages/**/*.{js,jsx,ts,tsx,vue}",
          "**/routes/**/*.{jsx,tsx,vue,svelte}",
          "**/frontend/**/*.js"
        ]
      },
      "target": "web",
      "scope": "local",
      "substitutionKeys": []
    },
    "audit-devops": {
      "triggers": {
        "gates": ["gate1", "gate3"],
        "keywords": ["ci", "deploy", "docker", "k8s", "terraform", "workflow"],
        "filePatterns": [
          ".github/workflows/**",
          "**/Dockerfile",
          "infra/**",
          "**/*.tf"
        ]
      },
      "scope": "cumulative",
      "substitutionKeys": []
    },
    "audit-sre": {
      "triggers": {
        "gates": ["gate3"],
        "keywords": [
          "sre",
          "slo",
          "observability",
          "runbook",
          "rollback",
          "error budget",
          "on-call",
          "incident",
          "resilience"
        ],
        "filePatterns": [
          "**/Dockerfile",
          "**/Dockerfile.*",
          "**/migrations/**",
          "**/deploy/**",
          "**/*deploy*.sh",
          ".github/workflows/**",
          "**/*health*"
        ]
      },
      "scope": "cumulative",
      "substitutionKeys": []
    },
    "audit-documentation": {
      "triggers": {
        "gates": ["gate1", "gate3"],
        "keywords": [
          "documentation",
          "docs",
          "readme",
          "changelog",
          "runbook",
          "stale docs"
        ],
        "filePatterns": [
          "**/*.md",
          "docs/**",
          ".agents/docs/**",
          ".agents/workflows/**"
        ]
      },
      "scope": "cumulative",
      "substitutionKeys": []
    },
    "audit-dependencies": {
      "triggers": {
        "gates": ["gate1", "gate3"],
        "keywords": [
          "dependency",
          "dependencies",
          "package",
          "vulnerability",
          "cve",
          "upgrade",
          "supply chain"
        ],
        "filePatterns": [
          "**/package.json",
          "**/package-lock.json",
          "**/pnpm-lock.yaml",
          "**/yarn.lock"
        ]
      },
      "scope": "cumulative",
      "substitutionKeys": []
    },
    "audit-performance": {
      "triggers": {
        "gates": ["gate1", "gate3"],
        "keywords": [
          "performance",
          "n+1",
          "hot path",
          "latency",
          "throughput",
          "concurrency",
          "race",
          "toctou",
          "atomic",
          "idempotent",
          "bundle",
          "memory leak"
        ],
        "filePatterns": [
          ".agents/scripts/**",
          "src/**/*.{ts,js}",
          "**/*.html",
          "**/*.css",
          "**/components/**/*.js"
        ]
      },
      "scope": "local",
      "substitutionKeys": []
    },
    "audit-quality": {
      "triggers": {
        "gates": ["gate1", "gate3"],
        "keywords": ["test", "coverage", "flaky", "assertion"],
        "sourceWithoutSiblingTest": true
      },
      "scope": "local",
      "substitutionKeys": []
    },
    "audit-seo": {
      "triggers": {
        "gates": ["gate2", "gate3"],
        "keywords": ["seo", "meta", "structured data", "schema.org", "sitemap"],
        "filePatterns": [
          "**/*.html",
          "**/*.astro",
          "**/sitemap*",
          "**/robots*",
          "**/app/**/{page,layout,route,head,default,template,loading,error,not-found,opengraph-image,twitter-image}.{js,jsx,ts,tsx}",
          "**/pages/**/*.{js,jsx,ts,tsx,vue}",
          "**/routes/**/*.{jsx,tsx,vue,svelte}"
        ]
      },
      "target": "web",
      "scope": "local",
      "substitutionKeys": []
    },
    "audit-ux-ui": {
      "triggers": {
        "gates": ["gate2", "gate3"],
        "keywords": ["ux", "ui", "design tokens", "component", "accessibility"],
        "filePatterns": [
          "**/components/**/*.{tsx,jsx,vue,svelte}",
          "**/styles/**",
          "**/*.css",
          "**/*.{scss,sass,less}",
          "**/tailwind.config.{js,ts,cjs,mjs}",
          "**/theme/**",
          "**/tokens/**",
          "**/design-system/**"
        ]
      },
      "target": "web",
      "scope": "local",
      "substitutionKeys": []
    },
    "audit-navigability": {
      "triggers": {
        "gates": ["gate2", "gate3"],
        "keywords": [
          "navigability",
          "reachability",
          "nav registry",
          "route tree"
        ]
      },
      "target": "web",
      "scope": "global",
      "substitutionKeys": []
    }
  },
  "sensitivePaths": {
    "security": {
      "description": "Authentication, authorization, session, and secret-handling surfaces.",
      "filePatterns": [
        "**/auth/**",
        "**/authn/**",
        "**/authz/**",
        "**/crypto/**",
        "**/session/**",
        "**/*credential*",
        "**/*permission*",
        "**/*.pem",
        "**/*.key"
      ]
    },
    "data-migration": {
      "description": "Schema migrations and seed data — changes that rewrite persisted state.",
      "filePatterns": [
        "**/migrations/**",
        "**/migrate/**",
        "**/seeds/**",
        "**/*.sql",
        "**/schema.prisma"
      ]
    },
    "billing": {
      "description": "Money movement: payment, checkout, invoicing, and subscription surfaces.",
      "filePatterns": [
        "**/billing/**",
        "**/payment/**",
        "**/payments/**",
        "**/checkout/**",
        "**/invoice*/**",
        "**/subscription*/**"
      ]
    },
    "destructive-mutation": {
      "description": "Irreversible mutation paths — deletion, purge, and teardown.",
      "filePatterns": ["**/*delete*", "**/*destroy*", "**/*purge*"]
    },
    "public-api": {
      "description": "The externally-consumed contract surface: routes, controllers, and API schemas.",
      "filePatterns": [
        "**/api/**",
        "**/routes/**",
        "**/controllers/**",
        "**/openapi/**",
        "**/graphql/**"
      ]
    }
  }
}
