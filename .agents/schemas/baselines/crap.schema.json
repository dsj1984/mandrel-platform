{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mandrel/.agents/schemas/baselines/crap.schema.json",
  "title": "CrapBaselineV2",
  "description": "Per-kind baseline schema for the CRAP gate, envelope-shaped. Extends the shared baseline-envelope contract. Distinct from the legacy crap-baseline.schema.json which used a flat shape.",
  "allOf": [{ "$ref": "baseline-envelope.schema.json" }],
  "type": "object",
  "properties": {
    "rollup": {
      "type": "object",
      "required": ["*"],
      "additionalProperties": {
        "type": "object",
        "required": ["p50", "p95", "max", "methodsAbove20"],
        "additionalProperties": false,
        "properties": {
          "p50": { "type": "number", "minimum": 0 },
          "p95": { "type": "number", "minimum": 0 },
          "max": { "type": "number", "minimum": 0 },
          "methodsAbove20": { "type": "integer", "minimum": 0 }
        }
      },
      "properties": {
        "*": {
          "type": "object",
          "required": ["p50", "p95", "max", "methodsAbove20"],
          "additionalProperties": false,
          "properties": {
            "p50": { "type": "number", "minimum": 0 },
            "p95": { "type": "number", "minimum": 0 },
            "max": { "type": "number", "minimum": 0 },
            "methodsAbove20": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "method", "startLine", "crap"],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string" },
          "method": { "type": "string" },
          "startLine": { "type": "integer", "minimum": 1 },
          "crap": { "type": "number", "minimum": 0 }
        }
      }
    }
  }
}
