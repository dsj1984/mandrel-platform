{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FrictionEvent",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "sprintId": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "Prompt Ambiguity",
        "Missing Skill",
        "Incorrect Persona",
        "Tool Limitation",
        "Execution Error"
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tool": {
          "type": "string"
        },
        "command": {
          "type": "string"
        }
      }
    },
    "details": {
      "type": "string",
      "description": "Specific error message or observation."
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "protocolFile": {
          "type": "string",
          "description": "Path to relevant protocol file, e.g., '.agents/skills/core/tdd.md'"
        }
      }
    }
  },
  "required": ["eventId", "timestamp", "sprintId", "category", "details"]
}
