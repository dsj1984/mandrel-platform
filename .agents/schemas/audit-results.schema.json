{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AuditResults",
  "description": "Standardized output format for the audit orchestration suite",
  "type": "object",
  "required": ["summary", "results"],
  "additionalProperties": false,
  "properties": {
    "summary": {
      "type": "object",
      "required": [
        "auditsRun",
        "totalFindings",
        "critical",
        "high",
        "medium",
        "low"
      ],
      "additionalProperties": false,
      "properties": {
        "auditsRun": {
          "type": "array",
          "items": { "type": "string" }
        },
        "totalFindings": { "type": "integer", "minimum": 0 },
        "critical": { "type": "integer", "minimum": 0 },
        "high": { "type": "integer", "minimum": 0 },
        "medium": { "type": "integer", "minimum": 0 },
        "low": { "type": "integer", "minimum": 0 }
      }
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "auditId",
          "checkId",
          "severity",
          "message",
          "location",
          "recommendation"
        ],
        "additionalProperties": false,
        "properties": {
          "auditId": { "type": "string" },
          "checkId": { "type": "string" },
          "fixId": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["Critical", "High", "Medium", "Low", "Info"]
          },
          "message": { "type": "string" },
          "location": {
            "type": "object",
            "required": ["file"],
            "additionalProperties": false,
            "properties": {
              "file": { "type": "string" },
              "line": { "type": "integer" },
              "column": { "type": "integer" }
            }
          },
          "recommendation": { "type": "string" }
        }
      }
    }
  }
}
