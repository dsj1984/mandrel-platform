{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash",
      "Bash(git stash:*)",
      "mcp__github__*",
      "Bash(grep -E --line-buffered \"Wave|wave|launched|Launched|blocked|BLOCKED|completed|COMPLETED|Fatal|FAIL|fail|Error|error|review|Epic|\\\\\\\\[DONE\\\\\\\\]|has no\")"
    ],
    "deny": [
      "Bash(git reset --hard*)",
      "Bash(git clean *)",
      "Bash(rm -rf *)",
      "Bash(rmdir *)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node bin/mandrel.js sync-commands"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(rm -rf *)",
            "command": "node -e 'let s=\"\";process.stdin.on(\"data\",d=>s+=d);process.stdin.on(\"end\",()=>{try{const c=JSON.parse(s).tool_input.command;if(/\\brm\\s+-rf\\s+([^\\s]*\\/)?\\.worktrees\\//.test(c))console.log(JSON.stringify({hookSpecificOutput:{hookEventName:\"PreToolUse\",permissionDecision:\"allow\",permissionDecisionReason:\"target inside .worktrees/\"}}));else console.log(\"{}\");}catch(e){console.log(\"{}\");}})'"
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|Read|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "node .agents/scripts/lib/observability/tool-trace-hook.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|Read|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "node .agents/scripts/lib/observability/tool-trace-hook.js"
          }
        ]
      }
    ]
  },
  "defaultMode": "acceptEdits"
}
